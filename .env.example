# Copy to .env.local for local development.

# Public API URL (browser may use this when not using the dev proxy)
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000/api/v1

# Set to 0 or false to call NEXT_PUBLIC_API_URL directly from the browser (needs CORS on API)
# NEXT_PUBLIC_USE_DEV_PROXY=0

# Server-side: backend origin for Pages API proxy (no /api/v1 suffix)
API_PROXY_TARGET=http://127.0.0.1:4000

# Alternative name also supported by the proxy route
# INTERNAL_API_URL=http://127.0.0.1:4000
